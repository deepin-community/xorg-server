Index: xorg-pointer-fix/randr/rrpointer.c
===================================================================
--- xorg-pointer-fix.orig/randr/rrpointer.c
+++ xorg-pointer-fix/randr/rrpointer.c
@@ -147,7 +147,24 @@ RRPointerScreenConfigured(ScreenPtr pScr
 
             if (pScreen == pCurrentScreen) {
                 GetSpritePosition(pDev, &x, &y);
+                rrScrPriv(pScreen);
+                if (pScrPriv->numCrtcs > 1 &&
+                    pScrPriv->primaryOutput && pScrPriv->primaryOutput->crtc &&
+                    !RRCrtcContainsPosition(pScrPriv->primaryOutput->crtc, x, y)) {
+                    RRCrtcPtr primary_crtc = pScrPriv->primaryOutput->crtc;
+                    RRModePtr mode = primary_crtc->mode;
+                    if (mode) {
+                        int sw, sh;
+                        RRCrtcGetScanoutSize(primary_crtc, &sw, &sh);
+                        x = primary_crtc->x + sw / 2;
+                        y = primary_crtc->y + sh / 2;
+                        (*pScreen->SetCursorPosition)(pDev, pScreen, x, y, TRUE);
+                        pScrPriv->pointerCrtc = primary_crtc;
+                        GetSpritePosition(pDev, &x, &y);
+                    }
+                }
                 RRPointerToNearestCrtc(pDev, pScreen, x, y, NULL);
+
             }
         }
     }
